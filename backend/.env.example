# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=onehealth_cms

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Upload limits
MAX_FILE_SIZE=52428800

# TinyMCE API Key (get from tiny.cloud)
TINYMCE_API_KEY=your-tinymce-api-key

# Email (SMTP) Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@onehealth.cm

# SMS Configuration - Africa's Talking (primary for Cameroon)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-africastalking-username
AT_SENDER_ID=OneHealth
# Set SMS_FORCE_SEND=true to send real SMS in development mode
# SMS_FORCE_SEND=false

# SMS Configuration - Twilio (fallback)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Push Notifications
# Option 1: JSON string of service account credentials
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Option 2: Path to service account JSON file
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# Set PUSH_FORCE_SEND=true to send real push notifications in development mode
# PUSH_FORCE_SEND=false
